WATCHBELL_ADMIN_USERNAME=admin
WATCHBELL_ADMIN_PASSWORD=change-me
WATCHBELL_SESSION_SECRET=replace-with-at-least-32-random-bytes
WATCHBELL_COOKIE_SECURE=
WATCHBELL_TRUST_PROXY_HEADERS=false
WATCHBELL_TRUSTED_PROXY_HOPS=1
WATCHBELL_LOGIN_MAX_FAILURES=5
WATCHBELL_LOGIN_FAILURE_WINDOW=15m
WATCHBELL_HISTORY_RETENTION=90d
# 可选单独覆盖：WATCHBELL_EVENT_RETENTION / WATCHBELL_CHECK_RUN_RETENTION /
# WATCHBELL_NOTIFICATION_ATTEMPT_RETENTION / WATCHBELL_AUDIT_LOG_RETENTION
WATCHBELL_HISTORY_CLEANUP_INTERVAL=6h
WATCHBELL_HISTORY_CLEANUP_BATCH=500
WATCHBELL_IMAGE=watchbell:local
WATCHBELL_VERSION=dev
WATCHBELL_VCS_REF=local
WATCHBELL_BUILD_DATE=unknown
WATCHBELL_SOURCE_URL=https://github.com/watchbell/watchbell
