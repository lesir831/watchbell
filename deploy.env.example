WATCHBELL_IMAGE=ghcr.io/lesir831/watchbell:latest
WATCHBELL_BIND_IP=0.0.0.0
WATCHBELL_PORT=8080

WATCHBELL_ADMIN_USERNAME=admin
WATCHBELL_ADMIN_PASSWORD=replace-with-a-strong-password
WATCHBELL_SESSION_SECRET=replace-with-at-least-32-random-bytes
WATCHBELL_SESSION_TTL=168h

WATCHBELL_WORKERS=2
WATCHBELL_SCHEDULER_TICK=10s
WATCHBELL_LOG_LEVEL=info
